# ============================================================================
# Calendar.io — Environment variables
# ============================================================================
# Copy this file to .env.local for local development.
# For Vercel, paste these into the Project Settings → Environment Variables.
# ============================================================================

# -- Database (Turso in prod, local SQLite file in dev) --
# In dev you can leave TURSO_URL blank; the app will use ./data/calendar.db.
# In prod, set both.
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_TOKEN=your-turso-auth-token

# -- Admin password --
# The password required to access the admin dashboard.
# If unset, the admin UI is open (useful for local dev only).
ADMIN_PASSWORD=pick-a-strong-password

# -- Google Calendar OAuth --
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API first.
# Authorized redirect URI: https://your-domain.com/api/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google/callback

# -- Resend (email delivery) --
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# Add your domain in Resend and verify it with DNS records before using.
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# -- Cron secret (Vercel cron only) --
# Random string. Protects /api/workflows/execute from unauthorized hits.
# Vercel automatically sends this as the Authorization header when the crons
# in vercel.json fire. Leave blank to disable the check.
CRON_SECRET=
